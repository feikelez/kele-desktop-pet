{
  "name": "kele-desktop-pet",
  "version": "1.0.0",
  "description": "Stardew Valley desktop pet - 猫猫与Sebastian在桌面上陪你",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "keywords": [],
  "author": "kelez",
  "license": "MIT",
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.15.2"
  },
  "dependencies": {},
  "build": {
    "appId": "com.kele.desktop-pet",
    "productName": "星露谷桌面宠物",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**",
      "assets/**",
      "!**/*.map",
      "!**/*.md",
      "!**/test/**",
      "!**/tests/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/app-icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/app-icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "星露谷桌面宠物"
    },
    "compression": "maximum"
  }
}